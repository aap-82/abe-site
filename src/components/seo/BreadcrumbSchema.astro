---
const { course, jurisdiction } = Astro.props;
const d = course.data;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://abeeducation.edu.au/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Courses",
      "item": "https://abeeducation.edu.au/courses/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": jurisdiction.data.name,
      "item": `https://abeeducation.edu.au/courses/${d.slug}/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": d.title
    }
  ]
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
