---
/**
 * AnswerCapsule — the page's canonical answer paragraph.
 *
 * Used wherever a page (or section) needs to surface "the short version" —
 * the single quotable statement that AI Overviews and feature snippets
 * tend to pull. Marked with `data-answer-capsule` so AI parsers can find
 * it without relying on positional heuristics.
 *
 * TWO VARIANTS
 * ────────────
 *
 * variant="editorial" (default)
 *   THE SHORT VERSION                              ← mono eyebrow
 *
 *   The answer paragraph, set in DM Sans 500       ← body, the TYPE is
 *   at xl/2xl. Larger and weightier than             the container; no
 *   surrounding body — the type IS the container.    card, tint, or border.
 *
 *   ─────────────────────                          ← hairline rule
 *   Verified against {Source} on {Date}.           ← mono citation
 *
 * variant="subtle"
 *   ┌─────────────────────────────────────────┐
 *   │                                          │
 *   │  The answer paragraph, set in DM Sans   │   ← Cool Off-White
 *   │  500 at xl/2xl. Same body treatment       (bg-base-200) block,
 *   │  as editorial.                            │   no border, no shadow.
 *   │                                          │
 *   │  Verified against {Source} on {Date}.   │   ← citation, separated
 *   │                                          │     by space alone (no
 *   └─────────────────────────────────────────┘     hairline rule).
 *
 *   No eyebrow. The bg tint quietly signals "this is set apart".
 *   Useful inside a section that already has a heading, or when
 *   the editorial composition would compete with surrounding chrome.
 *
 * Anti-slop discipline (both variants):
 *   - No alert / callout tint (success/warning/error semantics)
 *   - No info icon
 *   - No side-stripe border (banned absolutely)
 *   - No gradient text (banned absolutely)
 *   - No drop shadow, no glow
 *   - Heritage Maroon used in ZERO places by default (the citation
 *     link picks up Maroon on hover only)
 */

interface Source {
  /** Display name of the source — e.g. "Building Commission NSW". */
  name: string;
  /** Optional URL for the source — renders the name as a dotted-underline link. */
  url?: string;
  /** ISO date string (YYYY-MM-DD) when the answer was last verified against this source. */
  date: string;
}

interface Props {
  /** The canonical answer paragraph. 40–60 words is the sweet spot for AI Overview extraction. */
  text: string;
  /** Eyebrow override; defaults to "The short version". Ignored when variant="subtle". */
  eyebrow?: string;
  /** Optional source citation rendered below the body. */
  source?: Source;
  /**
   * Visual treatment.
   *   - "editorial" (default): uncontainered. Eyebrow + body + hairline-rule citation.
   *   - "subtle": bg-base-200 block. No eyebrow, no hairline. Just body + spaced citation.
   */
  variant?: 'editorial' | 'subtle';
  /** Outer wrapper additional classes (for spacing or width overrides). */
  class?: string;
}

const {
  text,
  eyebrow = 'The short version',
  source,
  variant = 'editorial',
  class: cls = '',
} = Astro.props;

const isSubtle = variant === 'subtle';

const wrapperClasses = isSubtle
  ? ['bg-base-200 rounded-box p-6 lg:p-8 max-w-prose', cls]
  : ['max-w-prose', cls];

const sourceWrapperClasses = isSubtle
  ? 'mt-6'
  : 'mt-7 lg:mt-9 pt-4 border-t border-base-300 max-w-md';

const formattedDate = source
  ? new Intl.DateTimeFormat('en-AU', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(source.date))
  : null;
---

<div data-answer-capsule class:list={wrapperClasses}>

  {/* Eyebrow — editorial variant only */}
  {!isSubtle && (
    <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-4">
      {eyebrow}
    </p>
  )}

  {/* The answer itself — same type treatment in both variants. */}
  <p class="text-xl lg:text-2xl leading-[1.55] font-medium text-base-content">
    {text}
  </p>

  {/* Optional source citation. Editorial: hairline + max-w-md.
      Subtle: just spaced below, no rule. */}
  {source && (
    <div class:list={sourceWrapperClasses}>
      <p class="font-mono text-xs leading-relaxed text-base-content/55">
        Verified against{' '}
        {source.url ? (
          <a
            href={source.url}
            class="text-base-content/85 underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors"
            rel="noopener"
          >
            {source.name}
          </a>
        ) : (
          <span class="text-base-content/85">{source.name}</span>
        )}
        {' '}on {formattedDate}.
      </p>
    </div>
  )}
</div>
