---
// CtaBanner — final-CTA block before the trust footer.
// Two-column panel + inline-SVG decorative image (no external loads).
// Driven by props so it can be reused across product pages.
//
// Per build spec section 3.4 / mockup HyperUI verbatim pattern. Zero JS.

interface Props {
  title: string;
  description?: string;
  ctaLabel: string;
  ctaHref: string;
}

const { title, description, ctaLabel, ctaHref } = Astro.props;
---

<section>
  <div class="mx-auto max-w-screen-2xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

      {/* Maroon panel */}
      <div class="bg-primary p-8 md:p-12 lg:px-16 lg:py-24 rounded-lg">
        <div class="mx-auto max-w-xl text-center">
          <h2 class="font-display text-2xl font-bold text-primary-content md:text-3xl">
            {title}
          </h2>
          {description && (
            <p class="hidden text-primary-content/90 sm:mt-4 sm:block">
              {description}
            </p>
          )}
          <div class="mt-4 md:mt-8">
            <a
              href={ctaHref}
              class="inline-block rounded-sm border border-primary-content bg-primary-content px-12 py-3 text-sm font-medium text-primary transition hover:bg-transparent hover:text-primary-content focus:ring-2 focus:ring-accent focus:outline-hidden"
              data-cta="final-banner-enrol"
            >
              {ctaLabel}
            </a>
          </div>
        </div>
      </div>

      {/* Decorative pattern panel — pure CSS, no external image */}
      <div class="grid grid-cols-2 gap-4 md:grid-cols-1 lg:grid-cols-2">
        <div class="h-40 sm:h-56 md:h-full rounded-lg bg-gradient-to-br from-base-200 via-base-300 to-base-200 relative overflow-hidden">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 200 200"
            class="absolute inset-4 w-[calc(100%-2rem)] h-[calc(100%-2rem)] text-primary/30"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <path d="M20 180 L20 60 L100 20 L180 60 L180 180 Z" />
            <path d="M20 60 L100 20 L180 60" />
            <line x1="20" y1="180" x2="180" y2="180" />
          </svg>
        </div>
        <div class="h-40 sm:h-56 md:h-full rounded-lg bg-gradient-to-br from-secondary/20 via-base-200 to-accent/30 relative overflow-hidden">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 200 200"
            class="absolute inset-4 w-[calc(100%-2rem)] h-[calc(100%-2rem)] text-secondary/40"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <rect x="40" y="40" width="120" height="120" rx="4" />
            <line x1="40" y1="80" x2="160" y2="80" />
            <line x1="40" y1="120" x2="160" y2="120" />
            <line x1="80" y1="40" x2="80" y2="160" />
            <line x1="120" y1="40" x2="120" y2="160" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
