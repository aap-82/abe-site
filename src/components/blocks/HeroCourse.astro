---
// HeroCourse — course page hero, designed per the v0.3 visual mockup.
//
// Layout: 12-col grid (8 content + 4 image) on desktop, stacked on mobile.
// Reviewer credit + breadcrumbs live in the separate <BreadcrumbsBar>
// component above this hero — keeps things composable and lets the
// breadcrumb bar span full-width while the hero panel rounds.
//
// Image column: pure CSS gradient + inline SVG (no external image
// dependency). Replace with a real <Image> when art is finalised.
//
// Zero JavaScript shipped.

import type { CollectionEntry } from 'astro:content';

interface Props {
  course: CollectionEntry<'courses'>;
  jurisdiction: CollectionEntry<'jurisdictions'>;
  reviewer: CollectionEntry<'experts'>;
}

const { course, jurisdiction, reviewer: _reviewer } = Astro.props;
const c = course.data;
const j = jurisdiction.data;

// Currency formatter — Intl is build-time, locale en-AU
const formattedPrice = new Intl.NumberFormat('en-AU', {
  style: 'currency',
  currency: c.priceCurrency,
  maximumFractionDigits: 0,
}).format(c.price);

// "April 2026" style for the eyebrow — derived from updatedAt
const updatedLabel = new Intl.DateTimeFormat('en-AU', {
  month: 'long',
  year: 'numeric',
}).format(new Date(c.updatedAt));

// H1 splits on " — " into a main line + colored sub-line, matching the
// mockup. Falls back to a single-line render if there's no separator.
const h1Parts = c.h1.split(' — ');
const h1Main = h1Parts[0];
const h1Sub = h1Parts.slice(1).join(' — ');

// Build-time integrity check — primary CTA must resolve
if (!c.enrolUrl) {
  throw new Error(`HeroCourse: missing enrolUrl on course "${course.id}"`);
}
---

<section>
  <div class="mx-auto max-w-screen-xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-x-8 gap-y-8 lg:grid-cols-12 lg:gap-y-16">

      {/* ─────── Content panel — bleeds right on desktop ─────── */}
      <div class="relative flex items-center bg-base-200 rounded-lg lg:col-span-8 lg:order-1">
        <span class="hidden lg:absolute lg:inset-y-0 lg:-right-16 lg:block lg:w-16 lg:bg-base-200 lg:rounded-r-lg" aria-hidden="true"></span>

        <div class="p-8 sm:p-12 lg:p-16">

          {/* ASQA Loc 1 — Hero inline disclosure */}
          <div class="inline-flex items-center gap-2 mb-4 px-3 py-1.5 bg-base-100 rounded-full text-xs font-medium border border-base-300">
            <span class="inline-block w-2 h-2 rounded-full bg-success" aria-hidden="true"></span>
            Training delivered by <strong>{c.deliveryRto.name}</strong> (RTO {c.deliveryRto.rtoCode}) &middot; Enrolled through ABE Education
          </div>

          <p class="text-xs uppercase tracking-widest text-primary/70 font-semibold mb-3">
            Last updated: {updatedLabel}
          </p>

          <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4 text-base-content">
            {h1Main}
            {h1Sub && (
              <span class="block text-primary mt-1">{h1Sub}</span>
            )}
          </h1>

          <p class="text-base sm:text-lg text-base-content/80 max-w-xl leading-relaxed mb-6">
            {c.answerCapsule}
          </p>

          {/* Dual CTAs */}
          <div class="flex flex-wrap gap-3 mb-8">
            <a
              href={c.enrolUrl}
              class="inline-block rounded-md border border-transparent bg-primary px-10 py-3 text-sm font-medium text-primary-content hover:bg-transparent hover:text-primary hover:border-primary focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 transition"
              data-cta="hero-enrol"
              data-course={c.slug}
            >
              Enrol now — {formattedPrice}
            </a>
            <a
              href="#course-details"
              class="inline-block rounded-md border border-base-content/20 px-10 py-3 text-sm font-medium text-base-content hover:bg-base-300 transition"
            >
              How it works
            </a>
          </div>

          {/* Stats trio */}
          <div class="stats stats-vertical sm:stats-horizontal shadow-sm border border-base-300 bg-base-100">
            <div class="stat py-3">
              <div class="stat-title text-xs">RTO Partner</div>
              <div class="stat-value text-base text-primary font-display">{c.deliveryRto.name}</div>
              <div class="stat-desc text-xs">RTO {c.deliveryRto.rtoCode} &middot; ASQA</div>
            </div>
            <div class="stat py-3">
              <div class="stat-title text-xs">Students Trained</div>
              <div class="stat-value text-base text-primary font-display">31,000+</div>
              <div class="stat-desc text-xs">Since 2007</div>
            </div>
            <div class="stat py-3">
              <div class="stat-title text-xs">Course Duration</div>
              <div class="stat-value text-base text-primary font-display">{c.duration}</div>
              <div class="stat-desc text-xs">Self-paced</div>
            </div>
          </div>
        </div>
      </div>

      {/* ─────── Image column — CSS gradient + inline SVG (no external load) ─────── */}
      <div class="relative z-10 lg:col-span-4 lg:py-12 lg:order-2">
        <div
          class="relative h-64 rounded-lg overflow-hidden sm:h-80 lg:h-full bg-gradient-to-br from-primary via-primary/80 to-secondary"
          role="img"
          aria-label={`${j.code} ${c.productLine.replace('-', ' ')} course illustration`}
        >
          <div class="absolute inset-0 flex items-center justify-center p-8">
            {/* Inline construction-blueprint SVG, primary-content tint */}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 200 200"
              class="w-full h-full max-w-[180px] text-primary-content/85"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              {/* Building outline */}
              <path d="M30 170 L30 80 L100 30 L170 80 L170 170 Z" />
              {/* Roof line */}
              <path d="M30 80 L100 30 L170 80" />
              {/* Door */}
              <rect x="85" y="120" width="30" height="50" />
              {/* Windows */}
              <rect x="50" y="100" width="22" height="22" />
              <rect x="128" y="100" width="22" height="22" />
              {/* Floor line */}
              <line x1="20" y1="170" x2="180" y2="170" />
              {/* Measurement marks */}
              <line x1="20" y1="170" x2="20" y2="180" />
              <line x1="180" y1="170" x2="180" y2="180" />
            </svg>
          </div>
          {/* Soft overlay for visual depth */}
          <div class="absolute inset-0 bg-gradient-to-tl from-primary/20 via-transparent to-transparent pointer-events-none"></div>
        </div>
      </div>
    </div>
  </div>
</section>
