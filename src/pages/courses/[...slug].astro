---
import { getCollection, getEntry, render } from 'astro:content';
import CourseLayout from '@/layouts/CourseLayout.astro';
import BreadcrumbsBar from '@/components/layout/BreadcrumbsBar.astro';
import HeroCourse from '@/components/blocks/HeroCourse.astro';
import EligibilityCards from '@/components/blocks/EligibilityCards.astro';
import HowItWorksSteps from '@/components/blocks/HowItWorksSteps.astro';
import UnitsTable from '@/components/blocks/UnitsTable.astro';
import PricingCard from '@/components/blocks/PricingCard.astro';
import WhyAbe from '@/components/blocks/WhyAbe.astro';
import CourseAuthorship from '@/components/blocks/CourseAuthorship.astro';
import WhoDelivers from '@/components/blocks/WhoDelivers.astro';
import CtaBanner from '@/components/blocks/CtaBanner.astro';
import TrustFooter from '@/components/blocks/TrustFooter.astro';
import StickyEnrolBar from '@/components/layout/StickyEnrolBar.astro';
import FaqAccordion from '@/components/content/FaqAccordion.astro';
import CourseSchema from '@/components/seo/CourseSchema.astro';
import BreadcrumbSchema from '@/components/seo/BreadcrumbSchema.astro';
import PersonSchema from '@/components/seo/PersonSchema.astro';
import FaqSchema from '@/components/seo/FaqSchema.astro';

export async function getStaticPaths() {
  const published = await getCollection('courses', (c) =>
    c.data.status === 'published'
  );

  return published.map((course) => ({
    params: { slug: course.id },
    props: { course }
  }));
}

const { course } = Astro.props;
const { Content } = await render(course);

// Resolve references
const jurisdiction = await getEntry(course.data.jurisdiction);
const reviewer = await getEntry(course.data.reviewer);
const developer = course.data.developer ? await getEntry(course.data.developer) : undefined;
const faqEntries = await Promise.all(course.data.faqRefs.map((ref) => getEntry(ref)));

if (!jurisdiction) {
  throw new Error(`Course ${course.id} references missing jurisdiction "${course.data.jurisdiction.id}"`);
}
if (!reviewer) {
  throw new Error(`Course ${course.id} references missing reviewer "${course.data.reviewer.id}"`);
}

const faqs = faqEntries.filter((f): f is NonNullable<typeof f> => f != null);
if (faqs.length !== faqEntries.length) {
  const missing = course.data.faqRefs
    .map((ref, i) => (faqEntries[i] == null ? ref.id : null))
    .filter((x): x is string => x != null);
  throw new Error(`Course ${course.id} references missing FAQs: ${missing.join(', ')}`);
}

// Build-time guard: prevent any prohibited claims from slipping into meta
for (const phrase of reviewer.data.prohibitedClaims) {
  if (course.data.metaDescription.toLowerCase().includes(phrase.toLowerCase())) {
    throw new Error(
      `Prohibited claim "${phrase}" found in meta description for ${course.id}`
    );
  }
}

const productLineLabel =
  course.data.productLine === 'owner-builder'
    ? 'Owner Builder Training'
    : course.data.productLine === 'white-card'
      ? 'White Card Training'
      : 'CPD Training';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: productLineLabel, href: '/compare/owner-builder/' },
  { label: `${jurisdiction.data.code} ${productLineLabel.replace(' Training', '')}`, href: null },
];
---

<CourseLayout course={course} jurisdiction={jurisdiction} reviewer={reviewer}>
  <Fragment slot="schema">
    <CourseSchema course={course} jurisdiction={jurisdiction} reviewer={reviewer} />
    <BreadcrumbSchema course={course} jurisdiction={jurisdiction} />
    <PersonSchema expert={reviewer} />
    {faqs.length > 0 && <FaqSchema faqs={faqs} />}
  </Fragment>

  <BreadcrumbsBar
    items={breadcrumbItems}
    reviewer={{
      name: reviewer.data.name,
      href: reviewer.data.profileUrl,
      date: course.data.lastReviewed,
    }}
  />

  <HeroCourse course={course} jurisdiction={jurisdiction} reviewer={reviewer} />

  {/* Section 1 + Section 4 narrative live in the markdown body */}
  <article id="course-details" class="prose max-w-3xl mx-auto px-4 py-14 lg:py-20">
    <Content />
  </article>

  <EligibilityCards course={course} jurisdiction={jurisdiction} />

  <HowItWorksSteps />

  <UnitsTable course={course} jurisdiction={jurisdiction} />

  <PricingCard course={course} jurisdiction={jurisdiction} />

  {faqs.length > 0 && (
    <section id="section-6" class="bg-base-200/50 border-t border-base-300 py-14 lg:py-20">
      <div class="mx-auto max-w-4xl px-4">
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-2">
          Frequently asked questions
        </h2>
        <p class="text-base-content/70 mb-8">
          Everything builders ask before they enrol.
        </p>
        <FaqAccordion faqs={faqs} />
      </div>
    </section>
  )}

  <WhyAbe course={course} jurisdiction={jurisdiction} />

  <CourseAuthorship course={course} developer={developer} reviewer={reviewer} />

  <WhoDelivers course={course} />

  <CtaBanner
    title="Get your Statement of Attainment in your inbox."
    description={`Self-paced. Nationally recognised. Delivered by ${course.data.deliveryRto.name} (RTO ${course.data.deliveryRto.rtoCode}) and accepted by ${jurisdiction.data.regulator.name}.`}
    ctaLabel={`Enrol now — $${course.data.price}`}
    ctaHref={course.data.enrolUrl}
  />

  <TrustFooter course={course} jurisdiction={jurisdiction} />

  <StickyEnrolBar course={course} />
</CourseLayout>
