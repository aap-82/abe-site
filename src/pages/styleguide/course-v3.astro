---
/**
 * Course page v3 — "The Handbook" — internal layout variant.
 *
 * The third full composition of the NSW Owner Builder course page. v1
 * (live, /courses/nsw-owner-builder-course/) is mockup-faithful and
 * card-driven. v2 (/styleguide/course-v2/) exercises every DaisyUI
 * component. v3 commits in the OPPOSITE direction: strip cards, strip
 * components, push the .impeccable.md "regulator handbook crossed with
 * editorial publication" voice to its limit.
 *
 * Aesthetic — committed direction
 * ───────────────────────────────
 *   - Type-driven. The TYPE is the container. No hero card. No tinted
 *     boxes around content. Hairline rules, not background bands.
 *   - § section marks (silcrow / pilcrow). Heritage Maroon used in three
 *     load-bearing places: the §s, hand-set numerals, and the primary CTA.
 *   - Marginalia layout on desktop ≥1024px — body in a 65ch column,
 *     small-caps mono asides hang in a right-margin track holding
 *     verification dates, RTO codes, source-document references.
 *     Marginalia collapses inline on mobile (footnote-style).
 *   - All-caps DM Mono running heads at the top of each major section,
 *     letter-spaced like a journal contents page.
 *   - Hand-set hanging-indent numerals for procedure rows. No icons.
 *
 * Anti-AI-slop (.impeccable.md anti-pattern list, all enforced)
 * ─────────────────────────────────────────────────────────────
 *   - Banned: side-stripe borders → not used
 *   - Banned: gradient text → not used
 *   - Banned: card-with-icon-and-heading repetition → not used
 *   - Banned: rounded-square icon tiles above every H2 → not used
 *   - Banned: countdown timers / scarcity / "limited spots" → not used
 *   - Banned: five-star carousels → not used
 *   - Banned: floating maroon glow on the CTA → not used
 *
 * Internal-only. noindex. Pulls the same NSW data as the canonical page
 * but emits no Course JSON-LD (would conflict with the live page's schema).
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import HowItWorksEditorial from '@/components/blocks/HowItWorksEditorial.astro';

const course = await getEntry('courses', 'nsw-owner-builder-course');
if (!course) {
  throw new Error(
    'NSW Owner Builder course not found — required for /styleguide/course-v3/. ' +
      'Check src/content/courses/nsw-owner-builder.md frontmatter slug.',
  );
}

const jurisdiction = await getEntry(course.data.jurisdiction);
const reviewer = await getEntry(course.data.reviewer);
// developer field removed — see § 07. NSW OB units are RTO-authored,
// so course-content authority belongs to AlertForce, not an ABE staff
// member. Other state OB pages (when built) keep the ABE-developer
// pattern because they're a different delivery model.
if (!jurisdiction || !reviewer) {
  throw new Error('Course references could not be resolved (jurisdiction or reviewer missing).');
}

const faqEntries = await Promise.all(course.data.faqRefs.map((ref) => getEntry(ref)));
const faqs = faqEntries.filter((f): f is NonNullable<typeof f> => f != null);

const c = course.data;
const r = reviewer.data;

const formattedPrice = new Intl.NumberFormat('en-AU', {
  style: 'currency',
  currency: c.priceCurrency,
  maximumFractionDigits: 0,
}).format(c.price);

const formattedReviewDate = new Intl.DateTimeFormat('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(c.lastReviewed));

const formattedReviewDateShort = new Intl.DateTimeFormat('en-AU', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(new Date(c.lastReviewed));

// Inclusions for the cost section. Keep as plain editorial list — five
// numbered items rendered as a procedure index, not a checklist with ticks.
const unitCodesString = c.unitCodes?.join(', ') ?? '';
const inclusions = [
  `Five units of competency: ${unitCodesString}.`,
  'Self-paced online learning with progress saved between sessions.',
  `Statement of Attainment issued by ${c.deliveryRto.name} (RTO ${c.deliveryRto.rtoCode}) on completion.`,
  'Recorded against your Unique Student Identifier on the National Training Register.',
  'Email and phone support from the partner RTO during business hours.',
];

// Plain-English outcome for each unit of competency. Keyed on the unit
// code so the lookup is independent of array order in frontmatter. The
// outcome answers "what will I actually be able to do?" in handbook
// voice — not the regulator phrasing of the unit title. DRAFT copy:
// reviewer to confirm against current AlertForce learner guides.
const unitOutcomes: Record<string, string> = {
  CPCCWHS2001:
    'Recognise common site hazards and apply the work-health-and-safety procedures that a residential building site is required to follow.',
  CPCCOM2001:
    'Read building plans, elevations, and specifications so you can check what your builder is actually proposing — and spot a discrepancy before it goes in the ground.',
  CPCCCM1011:
    'Estimate quantities and costs for materials and trades — the basis for the project value you declare on your Owner Builder Permit application.',
  CPCCOM1013:
    'Sequence the trades, deliveries, and inspections so the build moves through stages in the right order, without gaps or expensive standbys.',
  CPCCOM1014:
    'Brief your builders, log conversations, and document instructions in writing so the record holds up if something needs to be resolved later.',
};
---

<BaseLayout
  title="NSW Owner Builder Course (v3 — handbook composition, internal)"
  description="Internal handbook-composition variant of the NSW Owner Builder course page"
  noindex
>

  {/* Reading-progress hairline — fixed at the top of the viewport,
      grows from 0% to 100% width as the user scrolls. Steel rather
      than Heritage Maroon to keep maroon rare and load-bearing. */}
  <div class="reading-progress" aria-hidden="true"></div>

  {/* ─────────────────────────────────────────────────────────────────
       BREADCRUMB BAR — navigation on the left, freshness signal on the
       right. Per page-type-engine §4: › separator (U+203A),
       <nav aria-label="Breadcrumb">, current page non-clickable with
       aria-current. The currency-reviewer line on the right is the
       AI-Overview / E-E-A-T freshness signal.
     ───────────────────────────────────────────────────────────────── */}
  <nav id="top" aria-label="Breadcrumb" class="border-b border-base-300/70 bg-base-100">
    <div class="mx-auto max-w-6xl px-4 py-3 lg:py-4 flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">

      <ol class="flex flex-wrap items-baseline gap-x-2 gap-y-1 font-mono text-[11px] uppercase tracking-[0.18em] text-secondary">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-base-content/30">›</li>
        <li><a href="/compare/owner-builder/" class="hover:text-primary transition-colors">Owner Builder Training</a></li>
        <li aria-hidden="true" class="text-base-content/30">›</li>
        <li aria-current="page" class="text-base-content"><span data-current-section>NSW Owner Builder</span></li>
      </ol>

      <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-secondary">
        Currency reviewed by{' '}
        <a
          href="#section-authorship"
          class="text-base-content underline underline-offset-[3px] decoration-base-content/40 hover:text-primary hover:decoration-primary transition-colors"
        >{r.name}</a>{' '}
        · {formattedReviewDateShort}
      </p>

    </div>
  </nav>

  {/* ─────────────────────────────────────────────────────────────────
       MASTHEAD — title + lede + applies-to + fact panel.

       The fast-mover personas (WA / QLD OB pattern: 320 + 128 customers,
       single-session, compliance-motivated) want four answers above the
       fold: is this the right course, how much, how long, and who issues
       the certificate. The fact panel on the right answers all four
       without scrolling. The applies-to / not-for definition list under
       the lede answers "is this for me" before they have to find § 04.

       On mobile, the fact panel stacks BELOW the title block — the
       reading order on phone is title → lede → eligibility → fact
       panel + CTA, which matches the natural decision sequence. The
       reviewer dateline lives in the breadcrumb bar above, not here.
     ───────────────────────────────────────────────────────────────── */}
  <header class="border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 pt-12 lg:pt-20 pb-10 lg:pb-14">

      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-12 lg:gap-x-16 items-start">

        {/* ── Left column: title + lede + applies-to ──────────────── */}
        <div>
          <h1 class="font-display text-[2.5rem] sm:text-5xl lg:text-[4.25rem] leading-[1.05] lg:leading-none tracking-tight lg:tracking-[-0.03em] font-semibold text-base-content max-w-[18ch]">
            {c.h1.replace(/ — .*$/, '')}
          </h1>

          {/* Body Text Pairing — primary statement in charcoal/600,
              supporting clause in slate/400. The $20,000 emphasis gets
              a dotted underline in Cool Border (not a maroon accent
              per ABE Grey v1.1 — maroon stays load-bearing on the CTA). */}
          <p class="mt-5 lg:mt-7 max-w-[55ch] text-lg leading-relaxed">
            <span class="text-base-content font-semibold">
              The approved education you must complete before applying for an
              Owner Builder Permit when residential work on your home is valued
              at <strong class="font-semibold text-base-content underline decoration-dotted decoration-base-300 underline-offset-[3px]">$20,000 or more</strong>.
            </span>{' '}
            <span class="text-[#4a4a4a] font-normal">
              Five nationally recognised units, delivered online by{' '}
              {c.deliveryRto.name} (RTO {c.deliveryRto.rtoCode}).
            </span>
          </p>

          {/* Applies-to / Not-for — confirms eligibility above the fold.
              Mono labels on the left, body answers on the right. No
              icons, no ✓/✕ — that lives in § 04. This is the at-a-glance
              filter that sends the wrong audience away early. */}
          {c.eligibility && (
            <dl class="mt-8 lg:mt-10 max-w-[55ch] grid grid-cols-[6.5rem_minmax(0,1fr)] gap-x-5 gap-y-3 text-base lg:text-[1.0625rem] leading-relaxed">
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.45rem] leading-none">
                Applies to
              </dt>
              <dd class="text-base-content">
                {c.eligibility.eligible.join(', ')}.
              </dd>
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.45rem] leading-none">
                Not for
              </dt>
              <dd class="text-base-content/75">
                {c.eligibility.excluded.join(', ')}.
              </dd>
            </dl>
          )}
        </div>

        {/* ── Right column: fact panel ──────────────────────────────────
            Hairline left border on desktop, no border on mobile. This is
            the single-glance specification card a regulator handbook
            would put in the inside cover: price, format, RTO, button.
            No card chrome — the hairline and the type carry it. */}
        <aside class="lg:pt-2 lg:border-l lg:border-base-300 lg:pl-10">

          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-4">
            At a glance
          </p>

          <p class="font-display text-5xl lg:text-[4rem] font-semibold text-base-content leading-none tracking-tight lg:tracking-[-0.035em] tabular-nums lining-nums">
            {formattedPrice}
          </p>
          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.18em] text-secondary">
            One-off • GST included
          </p>

          <dl class="mt-7 grid grid-cols-[5.5rem_minmax(0,1fr)] gap-x-4 gap-y-3 text-sm leading-snug border-t border-base-300 pt-5">
            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.2rem]">
              Duration
            </dt>
            <dd class="text-base-content">{c.duration}</dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.2rem]">
              Format
            </dt>
            <dd class="text-base-content">Fully online • self-paced</dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.2rem]">
              Issued by
            </dt>
            <dd class="text-base-content">
              {c.deliveryRto.name}<br />
              <span class="font-mono text-xs text-base-content/65">RTO {c.deliveryRto.rtoCode}</span>
            </dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-secondary pt-[0.2rem]">
              You receive
            </dt>
            <dd class="text-base-content">{c.credentialAwarded}</dd>
          </dl>

          <a
            href={c.enrolUrl}
            class="btn btn-primary btn-md mt-7 w-full font-semibold"
          >
            Enrol now — {formattedPrice}
          </a>
          <p class="mt-3 font-mono text-[10px] text-base-content/55 leading-relaxed">
            No subscription. No add-ons.
          </p>

        </aside>
      </div>

    </div>
  </header>

  {/* ─────────────────────────────────────────────────────────────────
       § 02 — THE SHORT VERSION.
       Editorial AnswerCapsule (uncontainered, type-as-container) with
       the verified-source citation hairlined below. No card.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-short" class="bg-base-200/60 border-b border-base-300">
    {/* Vertical rhythm note — § 02 carries more breathing room than the
        adjacent sections (py-16 lg:py-24 vs the page's standard
        py-14 lg:py-20). This is the canonical answer block, the
        section AI Overviews are most likely to cite, and the place
        the page's voice lands first. The extra padding makes it read
        as a primary peak in the vertical rhythm. */}
    <div class="mx-auto max-w-6xl px-4 py-16 lg:py-24">
      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

        <div>
          <p data-section-eyebrow class="font-mono text-[11px] uppercase tracking-[0.22em] text-secondary mb-4">
            <span class="text-primary mr-1.5" aria-hidden="true">§</span>02 • In short
          </p>
          {/* Question H2 → answer capsule body. AI Overview citation
              patterns reward question-format headings followed by a
              40–60 word direct answer. The plain-English question is
              also what older homeowners actually scan for. */}
          <h2 class="font-display text-3xl lg:text-[2.875rem] font-semibold tracking-tight lg:tracking-[-0.03em] lg:leading-[1.05] text-base-content mb-5 lg:mb-6 max-w-prose">
            What is the NSW Owner Builder Course?
          </h2>
          <p class="text-lg leading-relaxed font-medium text-base-content max-w-prose">
            {c.answerCapsule}
          </p>
        </div>

        {/* Marginalia — small-caps mono asides */}
        <aside class="lg:pt-9 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-1">
              Threshold
            </span>
            Permit required at <strong class="font-semibold text-base-content">$10,000</strong>;
            course required at <strong class="font-semibold text-base-content">$20,000</strong>
            (residential building work, NSW).
          </p>
          <p>
            {/* "Verified" eyebrow in Success green (#059669 — brand-
                reserved for "confirmations / Eligible badges" per the
                Grey Design System v1.1 palette). The label IS the
                confirmation; the body text below it stays in regular
                reading colour. */}
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-success mb-1">
              Verified
            </span>
            <a
              href={`https://training.gov.au/Organisation/Details/${c.deliveryRto.rtoCode}`}
              class="underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors"
              rel="noopener"
            >training.gov.au</a>{' '}— RTO {c.deliveryRto.rtoCode}, {formattedReviewDateShort}.
          </p>
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-1">
              See also
            </span>
            <a href="#section-units" class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors">Units of competency</a>
            •{' '}
            <a href="#section-cost" class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors">Cost &amp; inclusions</a>
          </p>
        </aside>

      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 03 — How does the course work?
       Reuses HowItWorksEditorial. The numbered eyebrow keeps § 03 in
       the same running-head pattern as § 02 / § 04 / § 05 etc.
     ───────────────────────────────────────────────────────────────── */}
  <HowItWorksEditorial course={course} eyebrow="03 • How it works" />

  {/* ─────────────────────────────────────────────────────────────────
       § 04 — What this course doesn't cover.
       The masthead's "Applies to" line above the fold confirms the
       right cohort early. § 04's job is the warning side: the building
       types this course does NOT clear you for, so a wrong applicant
       turns away before they pay. Single column, hand-set ✕ in mono,
       hairline rules. The ✓ list has been retired here because it
       duplicated the masthead.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-eligibility" class="bg-base-200/60 border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-8 lg:mb-10">
        <div>
          <p data-section-eyebrow class="font-mono text-[11px] uppercase tracking-[0.22em] text-secondary mb-2">
            <span class="text-primary mr-1.5" aria-hidden="true">§</span>04 • Outside scope
          </p>
          <h2 class="font-display text-3xl lg:text-[2.875rem] font-semibold tracking-tight lg:tracking-[-0.03em] lg:leading-[1.05] text-base-content">
            Which projects sit outside this course?
          </h2>
        </div>
      </header>

      {/* Answer capsule — sets up the warning list and points to the
          exemption note for licence-holders who don't need the course. */}
      <p class="mb-10 lg:mb-14 max-w-[55ch] text-lg leading-relaxed text-base-content/85">
        Strata renovations, commercial premises, hotels and tourist
        accommodation, and moveable dwellings (including caravans) sit
        outside this course's scope. They need a different licensing
        pathway — usually a builder's licence rather than an Owner
        Builder Permit. A handful of existing NSW credentials also
        exempt you from the course requirement; see the note below.
      </p>

      {c.eligibility && (
        <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-secondary mb-5">
              Different pathway needed
            </p>
            <ul class="border-t border-base-300">
              {c.eligibility.excluded.map((item: string) => (
                <li class="border-b border-base-300 py-4 grid grid-cols-[1.5rem_minmax(0,1fr)] gap-x-3 items-baseline">
                  {/* ✕ in Error red (#dc2626 — brand-reserved for the
                      "prohibited / Excluded states" semantic per the
                      Grey Design System v1.1 palette). Single tactical
                      colour pop in the page's monochrome scheme. */}
                  <span class="font-mono text-base text-error leading-none" aria-hidden="true">✕</span>
                  <span class="text-base lg:text-[1.0625rem] text-base-content/85">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Marginalia — points back to the at-a-glance "Applies to"
              in the masthead so readers who land here understand where
              the positive list lives. */}
          <aside class="lg:pt-7 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
            <p>
              <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-1">
                For the positive list
              </span>
              See <a href="#top" class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors">"Applies to"</a> at the top of this page — single dwelling-house, secondary dwelling, dual occupancy.
            </p>
            <p>
              <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-1">
                Not sure?
              </span>
              <a
                href="https://www.nsw.gov.au/housing-and-construction/building-or-renovating-a-home/owner-builder/when-a-permit-needed"
                class="underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors"
                rel="noopener"
              >Building Commission&nbsp;NSW</a> publishes the full list of permit categories.
            </p>
          </aside>

        </div>
      )}

      {c.exemptionNote && (
        <p class="mt-12 lg:mt-14 max-w-prose text-sm leading-relaxed text-base-content/75">
          <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-secondary mb-2">
            Exemption note
          </span>
          {c.exemptionNote}
        </p>
      )}

      <p class="micro-cta mt-10">
        <a href="#section-units">↓ Read the unit specifications</a>
      </p>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 05 — Units of competency.
       Australian-Standards-style numbered specification index. No card,
       no zebra, no shadow. Mono unit codes left-aligned in a fixed
       column; plain-English title in the body column; superseded codes
       hang as a small mono note. Hairlines between rows.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-units" class="border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-8 lg:mb-10">
        <div>
          <p data-section-eyebrow class="font-mono text-[11px] uppercase tracking-[0.22em] text-secondary mb-2">
            <span class="text-primary mr-1.5" aria-hidden="true">§</span>05 • Units of competency
          </p>
          <h2 class="font-display text-3xl lg:text-[2.875rem] font-semibold tracking-tight lg:tracking-[-0.03em] lg:leading-[1.05] text-base-content">
            What will you learn?
          </h2>
        </div>
      </header>

      {/* Answer capsule — frames the unit list as the practical skill
          set behind the regulator phrasing. Five units, what each
          unlocks for the learner, who assesses them. */}
      <p class="mb-10 lg:mb-14 max-w-[55ch] text-lg leading-relaxed text-base-content/85">
        Five units of competency cover the core skills an Owner Builder
        needs to manage a residential build safely and legally: WHS on
        a building site, reading plans and specifications, basic
        estimation and costing, sequencing trades and inspections, and
        documenting site communication. Each unit is nationally
        recognised and assessed by {c.deliveryRto.name}.
      </p>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

        <ol class="border-t border-base-300">
          {(c.units ?? []).map((unit: { code: string; title: string; superseded?: string }, i: number) => (
            <li class="border-b border-base-300 py-6 lg:py-7 grid grid-cols-[2.5rem_minmax(0,1fr)] sm:grid-cols-[2.5rem_minmax(0,11rem)_minmax(0,1fr)] gap-x-5 lg:gap-x-8 items-baseline">
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-secondary leading-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-mono text-sm text-base-content leading-tight col-span-2 sm:col-span-1">
                {unit.code}
              </span>
              <div class="col-start-2 sm:col-start-3">
                {/* Regulator title kept verbatim (the unit-of-competency
                    name from training.gov.au) — given more weight so it
                    reads as a label for the outcome below. */}
                <p class="text-base lg:text-[1.0625rem] font-medium text-base-content leading-snug">
                  {unit.title}
                </p>
                {/* Plain-English outcome — what the learner will
                    actually be able to do, in handbook voice. Lookup
                    keyed on unit code. */}
                {unitOutcomes[unit.code] && (
                  <p class="mt-2 max-w-prose text-[15px] lg:text-base text-base-content/80 leading-relaxed">
                    {unitOutcomes[unit.code]}
                  </p>
                )}
                {unit.superseded && (
                  <p class="mt-2 font-mono text-[11px] text-base-content/55">
                    Supersedes {unit.superseded}
                  </p>
                )}
              </div>
            </li>
          ))}
        </ol>

        {/* Marginalia */}
        <aside class="lg:pt-7 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
          <p>
