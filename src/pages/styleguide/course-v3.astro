  {/* Section-aware breadcrumb — single Intersection Observer that
      tracks which section is currently in the upper-middle of the
      viewport and updates the breadcrumb's "NSW Owner Builder" label
      to include the active section ("§ 05 Units"). Only piece of the
      whole-page motion polish that needs JS — everything else is CSS.

      Observer fires only on threshold crossings, not on every scroll
      pixel, so it's cheap. Map state by section ID; pick the topmost
      currently-intersecting one in DOM order. */}
  <script is:inline>
    (() => {
      const target = document.querySelector('[data-current-section]');
      if (!target) return;
      const baseLabel = 'NSW Owner Builder';
      const sections = [
        { id: 'section-short', label: '§ 02 In short' },
        { id: 'section-2', label: '§ 03 How it works' },
        { id: 'section-eligibility', label: '§ 04 Outside scope' },
        { id: 'section-units', label: '§ 05 Units' },
        { id: 'section-cost', label: '§ 06 Cost' },
        { id: 'section-authorship', label: '§ 07 Authorship' },
        { id: 'section-why-abe', label: '§ 08 Why ABE' },
        { id: 'section-faqs', label: '§ 09 FAQs' },
      ];
      const states = new Map();
      let lastText = baseLabel;
      const update = () => {
        const active = sections.find(s => states.get(s.id));
        const next = active ? `${baseLabel} · ${active.label}` : baseLabel;
        if (next === lastText) return;
        lastText = next;
        target.textContent = next;
      };
      const observer = new IntersectionObserver((entries) => {
        for (const e of entries) states.set(e.target.id, e.isIntersecting);
        update();
      }, { rootMargin: '-25% 0px -55% 0px' });
      for (const s of sections) {
        const el = document.getElementById(s.id);
        if (el) observer.observe(el);
      }
    })();
  </script>

