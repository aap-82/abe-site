---
/**
 * Course page v3 — "The Handbook" — internal layout variant.
 *
 * The third full composition of the NSW Owner Builder course page. v1
 * (live, /courses/nsw-owner-builder-course/) is mockup-faithful and
 * card-driven. v2 (/styleguide/course-v2/) exercises every DaisyUI
 * component. v3 commits in the OPPOSITE direction: strip cards, strip
 * components, push the .impeccable.md "regulator handbook crossed with
 * editorial publication" voice to its limit.
 *
 * Aesthetic — committed direction
 * ───────────────────────────────
 *   - Type-driven. The TYPE is the container. No hero card. No tinted
 *     boxes around content. Hairline rules, not background bands.
 *   - § section marks (silcrow / pilcrow). Heritage Maroon used in three
 *     load-bearing places: the §s, hand-set numerals, and the primary CTA.
 *   - Marginalia layout on desktop ≥1024px — body in a 65ch column,
 *     small-caps mono asides hang in a right-margin track holding
 *     verification dates, RTO codes, source-document references.
 *     Marginalia collapses inline on mobile (footnote-style).
 *   - All-caps DM Mono running heads at the top of each major section,
 *     letter-spaced like a journal contents page.
 *   - Hand-set hanging-indent numerals for procedure rows. No icons.
 *
 * Anti-AI-slop (.impeccable.md anti-pattern list, all enforced)
 * ─────────────────────────────────────────────────────────────
 *   - Banned: side-stripe borders → not used
 *   - Banned: gradient text → not used
 *   - Banned: card-with-icon-and-heading repetition → not used
 *   - Banned: rounded-square icon tiles above every H2 → not used
 *   - Banned: countdown timers / scarcity / "limited spots" → not used
 *   - Banned: five-star carousels → not used
 *   - Banned: floating maroon glow on the CTA → not used
 *
 * Internal-only. noindex. Pulls the same NSW data as the canonical page
 * but emits no Course JSON-LD (would conflict with the live page's schema).
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import HowItWorksEditorial from '@/components/blocks/HowItWorksEditorial.astro';

const course = await getEntry('courses', 'nsw-owner-builder-course');
if (!course) {
  throw new Error(
    'NSW Owner Builder course not found — required for /styleguide/course-v3/. ' +
      'Check src/content/courses/nsw-owner-builder.md frontmatter slug.',
  );
}

const jurisdiction = await getEntry(course.data.jurisdiction);
const reviewer = await getEntry(course.data.reviewer);
// developer field removed — see § 07. NSW OB units are RTO-authored,
// so course-content authority belongs to AlertForce, not an ABE staff
// member. Other state OB pages (when built) keep the ABE-developer
// pattern because they're a different delivery model.
if (!jurisdiction || !reviewer) {
  throw new Error('Course references could not be resolved (jurisdiction or reviewer missing).');
}

const faqEntries = await Promise.all(course.data.faqRefs.map((ref) => getEntry(ref)));
const faqs = faqEntries.filter((f): f is NonNullable<typeof f> => f != null);

const c = course.data;
const j = jurisdiction.data;
const r = reviewer.data;

const formattedPrice = new Intl.NumberFormat('en-AU', {
  style: 'currency',
  currency: c.priceCurrency,
  maximumFractionDigits: 0,
}).format(c.price);

const formattedReviewDate = new Intl.DateTimeFormat('en-AU', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(c.lastReviewed));

const formattedReviewDateShort = new Intl.DateTimeFormat('en-AU', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
}).format(new Date(c.lastReviewed));

// Inclusions for the cost section. Keep as plain editorial list — five
// numbered items rendered as a procedure index, not a checklist with ticks.
const unitCodesString = c.unitCodes?.join(', ') ?? '';
const inclusions = [
  `Five units of competency: ${unitCodesString}.`,
  'Self-paced online learning with progress saved between sessions.',
  `Statement of Attainment issued by ${c.deliveryRto.name} (RTO ${c.deliveryRto.rtoCode}) on completion.`,
  'Recorded against your Unique Student Identifier on the National Training Register.',
  'Email and phone support from the partner RTO during business hours.',
];
---

<BaseLayout
  title="NSW Owner Builder Course (v3 — handbook composition, internal)"
  description="Internal handbook-composition variant of the NSW Owner Builder course page"
  noindex
>

  {/* ─────────────────────────────────────────────────────────────────
       MASTHEAD — title + lede + applies-to + dated byline + fact panel.

       The fast-mover personas (WA / QLD OB pattern: 320 + 128 customers,
       single-session, compliance-motivated) want four answers above the
       fold: is this the right course, how much, how long, and who issues
       the certificate. The fact panel on the right answers all four
       without scrolling. The applies-to / not-for definition list under
       the lede answers "is this for me" before they have to find § 04.

       On mobile, the fact panel stacks BELOW the title block — the
       reading order on phone is title → lede → eligibility → byline →
       fact panel + CTA, which matches the natural decision sequence.
     ───────────────────────────────────────────────────────────────── */}
  <header class="border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 pt-12 lg:pt-16 pb-10 lg:pb-14">

      {/* eyebrow row — running head + jurisdiction + filed-under */}
      <div class="flex flex-wrap items-baseline gap-x-6 gap-y-2 mb-8 lg:mb-12 font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55">
        <span aria-label="Jurisdiction">NSW • {j.regulator.shortName ?? j.regulator.name}</span>
        <span aria-hidden="true" class="text-base-content/30">/</span>
        <span>Owner Builder • Permit Education</span>
      </div>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-12 lg:gap-x-16 items-start">

        {/* ── Left column: title + lede + applies-to + byline ───────── */}
        <div>
          <h1 class="font-display text-[2.5rem] sm:text-5xl lg:text-[3.75rem] leading-[1.05] tracking-tight font-semibold text-base-content max-w-[18ch]">
            {c.h1.replace(/ — .*$/, '')}
          </h1>

          <p class="mt-5 lg:mt-7 max-w-[55ch] text-lg lg:text-xl leading-relaxed text-base-content/85">
            The approved education you must complete before applying for an
            Owner Builder Permit when residential work on your home is valued
            at <strong class="font-semibold text-base-content">$20,000 or more</strong>.
            Five nationally recognised units, delivered online by{' '}
            {c.deliveryRto.name} (RTO {c.deliveryRto.rtoCode}).
          </p>

          {/* Applies-to / Not-for — confirms eligibility above the fold.
              Mono labels on the left, body answers on the right. No
              icons, no ✓/✕ — that lives in § 04. This is the at-a-glance
              filter that sends the wrong audience away early. */}
          {c.eligibility && (
            <dl class="mt-8 lg:mt-10 max-w-[55ch] grid grid-cols-[6.5rem_minmax(0,1fr)] gap-x-5 gap-y-3 text-base lg:text-[1.0625rem] leading-relaxed">
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.45rem] leading-none">
                Applies to
              </dt>
              <dd class="text-base-content">
                {c.eligibility.eligible.join(', ')}.
              </dd>
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.45rem] leading-none">
                Not for
              </dt>
              <dd class="text-base-content/75">
                {c.eligibility.excluded.join(', ')}.
              </dd>
            </dl>
          )}

          {/* Dateline — like a journal byline. The course content is
              authored by the RTO; this line records who keeps the page
              CURRENT (legislation, regulator names, fees, unit codes). */}
          <div class="mt-8 lg:mt-10 flex flex-wrap items-baseline gap-x-6 gap-y-2 text-sm text-base-content/70">
            <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55">
              Currency reviewed
            </span>
            <span>
              {formattedReviewDate} by{' '}
              <a
                href={r.profileUrl}
                class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors"
              >{r.name}</a>, Compliance &amp; Currency Reviewer.
            </span>
          </div>
        </div>

        {/* ── Right column: fact panel ──────────────────────────────────
            Hairline left border on desktop, no border on mobile. This is
            the single-glance specification card a regulator handbook
            would put in the inside cover: price, format, RTO, button.
            No card chrome — the hairline and the type carry it. */}
        <aside class="lg:pt-2 lg:border-l lg:border-base-300 lg:pl-10">

          <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-4">
            At a glance
          </p>

          <p class="font-display text-5xl lg:text-6xl font-semibold text-base-content leading-none tracking-tight">
            {formattedPrice}
          </p>
          <p class="mt-2 font-mono text-[11px] uppercase tracking-[0.18em] text-base-content/55">
            One-off • GST included
          </p>

          <dl class="mt-7 grid grid-cols-[5.5rem_minmax(0,1fr)] gap-x-4 gap-y-3 text-sm leading-snug border-t border-base-300 pt-5">
            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.2rem]">
              Duration
            </dt>
            <dd class="text-base-content">{c.duration}</dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.2rem]">
              Format
            </dt>
            <dd class="text-base-content">Fully online • self-paced</dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.2rem]">
              Issued by
            </dt>
            <dd class="text-base-content">
              {c.deliveryRto.name}<br />
              <span class="font-mono text-xs text-base-content/65">RTO {c.deliveryRto.rtoCode}</span>
            </dd>

            <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 pt-[0.2rem]">
              You receive
            </dt>
            <dd class="text-base-content">{c.credentialAwarded}</dd>
          </dl>

          <a
            href={c.enrolUrl}
            class="btn btn-primary btn-md mt-7 w-full font-semibold"
          >
            Enrol now — {formattedPrice}
          </a>
          <p class="mt-3 font-mono text-[10px] text-base-content/55 leading-relaxed">
            No subscription. No add-ons.
          </p>

        </aside>
      </div>

    </div>
  </header>

  {/* ─────────────────────────────────────────────────────────────────
       § 02 — THE SHORT VERSION.
       Editorial AnswerCapsule (uncontainered, type-as-container) with
       the verified-source citation hairlined below. No card.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-short" class="bg-base-200/60 border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">
      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-4">
            02 • In short
          </p>
          <p class="text-xl lg:text-2xl leading-[1.55] font-medium text-base-content max-w-prose">
            {c.answerCapsule}
          </p>
        </div>

        {/* Marginalia — small-caps mono asides */}
        <aside class="lg:pt-9 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              Threshold
            </span>
            Permit required at <strong class="font-semibold text-base-content">$10,000</strong>;
            course required at <strong class="font-semibold text-base-content">$20,000</strong>
            (residential building work, NSW).
          </p>
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              Verified
            </span>
            <a
              href="https://www.nsw.gov.au/housing-and-construction/building-or-renovating-a-home/owner-builder/when-a-permit-needed"
              class="underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors"
              rel="noopener"
            >Building Commission&nbsp;NSW</a>{' '}— {formattedReviewDateShort}.
          </p>
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              See also
            </span>
            <a href="#section-units" class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors">Units of competency</a>
            •{' '}
            <a href="#section-cost" class="text-base-content underline underline-offset-[4px] decoration-base-content/40 hover:decoration-primary hover:text-primary transition-colors">Cost &amp; inclusions</a>
          </p>
        </aside>

      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 03 — How does the course work?
       Reuses HowItWorksEditorial. The numbered eyebrow keeps § 03 in
       the same running-head pattern as § 02 / § 04 / § 05 etc.
     ───────────────────────────────────────────────────────────────── */}
  <HowItWorksEditorial course={course} eyebrow="03 • How it works" />

  {/* ─────────────────────────────────────────────────────────────────
       § 04 — Who this course covers.
       Eligibility as a typographic definition list — NOT pill cards.
       Hand-set ✓ in maroon and ✕ in charcoal/55, mono unit codes,
       hairline rules. Two columns on desktop sharing a single rule.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-eligibility" class="bg-base-200/60 border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-10 lg:mb-14">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            04 • Eligibility
          </p>
          <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-base-content">
            Who this course covers — and who it doesn't
          </h2>
        </div>
      </header>

      {c.eligibility && (
        <div class="grid lg:grid-cols-2 gap-y-12 lg:gap-x-16">

          {/* Eligible */}
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-5">
              Covered — apply with this course
            </p>
            <ul class="border-t border-base-300">
              {c.eligibility.eligible.map((item: string) => (
                <li class="border-b border-base-300 py-4 grid grid-cols-[1.5rem_minmax(0,1fr)] gap-x-3 items-baseline">
                  <span class="font-display text-lg text-primary leading-none" aria-hidden="true">✓</span>
                  <span class="text-base lg:text-[1.0625rem] text-base-content">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          {/* Excluded */}
          <div>
            <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-5">
              Not covered — different pathway needed
            </p>
            <ul class="border-t border-base-300">
              {c.eligibility.excluded.map((item: string) => (
                <li class="border-b border-base-300 py-4 grid grid-cols-[1.5rem_minmax(0,1fr)] gap-x-3 items-baseline">
                  <span class="font-mono text-base text-base-content/55 leading-none" aria-hidden="true">✕</span>
                  <span class="text-base lg:text-[1.0625rem] text-base-content/85">{item}</span>
                </li>
              ))}
            </ul>
          </div>

        </div>
      )}

      {c.exemptionNote && (
        <p class="mt-12 lg:mt-14 max-w-prose text-sm leading-relaxed text-base-content/75">
          <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            Exemption note
          </span>
          {c.exemptionNote}
        </p>
      )}

      <p class="micro-cta mt-10">
        <a href="#section-units">↓ Read the unit specifications</a>
      </p>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 05 — Units of competency.
       Australian-Standards-style numbered specification index. No card,
       no zebra, no shadow. Mono unit codes left-aligned in a fixed
       column; plain-English title in the body column; superseded codes
       hang as a small mono note. Hairlines between rows.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-units" class="border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-10 lg:mb-14">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            05 • Units of competency
          </p>
          <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-base-content">
            Five nationally recognised units
          </h2>
        </div>
      </header>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

        <ol class="border-t border-base-300">
          {(c.units ?? []).map((unit: { code: string; title: string; superseded?: string }, i: number) => (
            <li class="border-b border-base-300 py-6 lg:py-7 grid grid-cols-[2.5rem_minmax(0,1fr)] sm:grid-cols-[2.5rem_minmax(0,11rem)_minmax(0,1fr)] gap-x-5 lg:gap-x-8 items-baseline">
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-base-content/55 leading-none">
                {String(i + 1).padStart(2, '0')}
              </span>
              <span class="font-mono text-sm text-base-content leading-tight col-span-2 sm:col-span-1">
                {unit.code}
              </span>
              <div class="col-start-2 sm:col-start-3">
                <p class="text-base lg:text-[1.0625rem] text-base-content leading-snug">
                  {unit.title}
                </p>
                {unit.superseded && (
                  <p class="mt-1 font-mono text-[11px] text-base-content/55">
                    Supersedes {unit.superseded}
                  </p>
                )}
              </div>
            </li>
          ))}
        </ol>

        {/* Marginalia */}
        <aside class="lg:pt-7 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              Verifiable on
            </span>
            <a
              href={`https://training.gov.au/Organisation/Details/${c.deliveryRto.rtoCode}`}
              class="underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors"
              rel="noopener"
            >training.gov.au</a>{' '}using RTO Code {c.deliveryRto.rtoCode}.
          </p>
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              Issuer
            </span>
            {c.credentialAwarded} issued by {c.deliveryRto.name} on completion.
          </p>
          <p>
            <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
              Recorded
            </span>
            Against your USI on the National Training Register.
          </p>
        </aside>

      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 06 — Cost & inclusions.
       Editorial figure block. The price is set as a single hand-set
       Archivo numeral — no card, no shadow, no border. A hairline rule
       sits below it; inclusions follow as a numbered procedure index.
       The single CTA is a maroon button. Nothing else competes.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-cost" class="bg-base-200/60 border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-10 lg:mb-14">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            06 • Cost &amp; what you receive
          </p>
          <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-base-content">
            One fee. Everything included.
          </h2>
        </div>
      </header>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1.1fr)] gap-y-12 lg:gap-x-20 items-start">

        {/* Price figure */}
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-3">
            The cost is
          </p>
          <p class="font-display font-semibold text-base-content leading-none tracking-tight text-7xl sm:text-8xl lg:text-[8.5rem]">
            {formattedPrice}
          </p>
          <p class="mt-4 font-mono text-xs uppercase tracking-[0.18em] text-base-content/55">
            One-off • GST included • {c.duration}
          </p>

          <div class="mt-10 max-w-md">
            <a
              href={c.enrolUrl}
              class="btn btn-primary btn-lg w-full sm:w-auto sm:min-w-[20rem] font-semibold"
            >
              Enrol now — {formattedPrice}
            </a>
            <p class="mt-4 font-mono text-[11px] text-base-content/55">
              Issued by {c.deliveryRto.name} (RTO {c.deliveryRto.rtoCode}).
              No subscription. No add-ons.
            </p>
          </div>
        </div>

        {/* Inclusions — numbered procedure index */}
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-5">
            Your fee covers
          </p>
          <ol class="border-t border-base-300">
            {inclusions.map((item: string, i: number) => (
              <li class="border-b border-base-300 py-4 grid grid-cols-[2rem_minmax(0,1fr)] gap-x-4 items-baseline">
                <span class="font-mono text-xs uppercase tracking-[0.18em] text-primary leading-none">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-base lg:text-[1.0625rem] text-base-content leading-snug">{item}</span>
              </li>
            ))}
          </ol>
        </div>

      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 07 — Course authority.
       Two-card editorial byline with content-authority on the LEFT
       (the RTO that authors and assesses the units) and currency
       review on the RIGHT (the named expert who keeps legislation,
       regulator names, fees and unit codes accurate over time).

       The course awards five nationally recognised units of
       competency and issues a Statement of Attainment — these are
       RTO functions. ABE Education is the enrolment partner and
       online platform, NOT the content author. Naming an ABE staff
       member here as "Course Developer" would misattribute the
       authorship and conflict with the dual-pathway authority model.
     ───────────────────────────────────────────────────────────────── */}
  <section id="section-authorship" class="border-b border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

      <header class="mb-10 lg:mb-14">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            07 • Course authority
          </p>
          <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-base-content">
            Who writes the course, and who keeps it current
          </h2>
        </div>
      </header>

      <div class="grid lg:grid-cols-2 gap-y-12 lg:gap-x-20">

        {/* ── Left card: RTO content authority ─────────────────────── */}
        <article>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-3">
            Course content
          </p>
          <h3 class="font-display text-2xl lg:text-3xl font-semibold text-base-content tracking-tight">
            <a
              href={`https://training.gov.au/Organisation/Details/${c.deliveryRto.rtoCode}`}
              class="underline underline-offset-[6px] decoration-base-content/30 hover:text-primary hover:decoration-primary transition-colors"
              rel="noopener"
            >{c.deliveryRto.name}</a>
          </h3>
          <p class="mt-2 text-base-content/75 text-base leading-relaxed">
            Registered Training Organisation, RTO {c.deliveryRto.rtoCode}.
          </p>
          <p class="mt-4 max-w-prose text-base-content leading-relaxed">
            {c.deliveryRto.name} authors and assesses the five
            nationally recognised units of competency that make up
            this course, and issues your Statement of Attainment on
            completion. {c.deliveryRto.name} is registered with the
            Australian Skills Quality Authority (ASQA) and listed on
            the National Training Register.
          </p>
          <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55">
            Verifiable on training.gov.au
          </p>
        </article>

        {/* ── Right card: independent currency reviewer ────────────── */}
        <article>
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-3">
            Currency reviewed by
          </p>
          <h3 class="font-display text-2xl lg:text-3xl font-semibold text-base-content tracking-tight">
            <a
              href={r.profileUrl}
              class="underline underline-offset-[6px] decoration-base-content/30 hover:text-primary hover:decoration-primary transition-colors"
            >{r.name}</a>
          </h3>
          <p class="mt-2 text-base-content/75 text-base leading-relaxed">
            Compliance &amp; Currency Reviewer{r.organisation ? `, ${r.organisation}` : ''}.
            {' '}
            {r.yearsInIndustry && `${r.yearsInIndustry} years across the Australian VET sector.`}
          </p>
          <p class="mt-4 max-w-prose text-base-content leading-relaxed">
            Reviews legislation references, regulator names, fee
            thresholds, and unit-code currency to keep this page
            accurate as the regulatory landscape changes — independently
            of {c.deliveryRto.name} and ABE Education.
          </p>
          <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55">
            Last currency review • {formattedReviewDate}
          </p>
        </article>

      </div>
    </div>
  </section>

  {/* ─────────────────────────────────────────────────────────────────
       § 08 — Frequently asked questions.
       Native <details> in handbook voice: hand-set Q.01, Q.02 markers,
       hairline separators, no chevrons-in-circles, no cards, no tints.
       Each summary opens to expose the answer typeset like body copy.
     ───────────────────────────────────────────────────────────────── */}
  {faqs.length > 0 && (
    <section id="section-faqs" class="bg-base-200/60 border-b border-base-300">
      <div class="mx-auto max-w-6xl px-4 py-14 lg:py-20">

        <header class="mb-10 lg:mb-14">
          <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 mb-2">
            08 • Common questions
          </p>
          <h2 class="font-display text-3xl lg:text-4xl font-semibold tracking-tight text-base-content">
            What builders ask before they enrol
          </h2>
        </header>

        <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,18rem)] gap-y-8 lg:gap-x-16">

          <ol class="border-t border-base-300 max-w-prose">
            {faqs.map((faq, i) => (
              <li class="border-b border-base-300">
                <details class="group">
                  <summary class="cursor-pointer list-none py-5 lg:py-6 grid grid-cols-[3rem_minmax(0,1fr)_1.25rem] gap-x-4 items-baseline hover:text-primary transition-colors">
                    <span class="font-mono text-xs uppercase tracking-[0.18em] text-base-content/55 leading-none">
                      Q.{String(i + 1).padStart(2, '0')}
                    </span>
                    <span class="font-display text-lg lg:text-xl font-medium text-base-content leading-snug group-hover:text-primary transition-colors">
                      {faq.data.question}
                    </span>
                    <span
                      class="font-mono text-base text-base-content/55 group-open:rotate-45 transition-transform leading-none justify-self-end"
                      aria-hidden="true"
                    >+</span>
                  </summary>
                  <div class="pl-[3.75rem] pr-4 pb-6 -mt-1 text-base lg:text-[1.0625rem] text-base-content/85 leading-relaxed prose prose-sm max-w-none prose-a:text-primary prose-a:underline prose-a:decoration-dotted prose-a:underline-offset-[3px]">
                    <p>{faq.data.answer}</p>
                  </div>
                </details>
              </li>
            ))}
          </ol>

          {/* Marginalia */}
          <aside class="lg:pt-6 lg:border-l lg:border-base-300 lg:pl-8 space-y-4 text-[13px] leading-relaxed text-base-content/60">
            <p>
              <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
                Still unsure?
              </span>
              Email <a href="mailto:hello@abeeducation.edu.au" class="underline decoration-dotted underline-offset-[3px] hover:text-primary transition-colors">hello@abeeducation.edu.au</a>{' '}
              — replies within one business day, Sydney time.
            </p>
            <p>
              <span class="block font-mono text-[10px] uppercase tracking-[0.22em] text-base-content/55 mb-1">
                Phone
              </span>
              02 8005 7382, 9am–5pm AEST.
            </p>
          </aside>

        </div>
      </div>
    </section>
  )}

  {/* §09 colophon removed — BaseLayout's site-wide footer already
      runs the partner-RTO disclosure and the "ABE is not an RTO"
      statement. The colophon was duplicating that information.
      Bottom padding handled by an empty spacer so the sticky enrol
      bar doesn't overlap the FAQ section. */}
  <div class="h-16 lg:h-20"></div>

  {/* ─────────────────────────────────────────────────────────────────
       Sticky bottom enrol — handbook footer dock.
       Cool Off-White (Base 200) bg, hairline top, mono price + single
       maroon CTA. Hidden on screens narrower than the body column so
       small phones aren't double-CTA'd above the keyboard.
     ───────────────────────────────────────────────────────────────── */}
  <div class="sticky bottom-0 z-40 hidden md:block bg-base-200/95 backdrop-blur-sm border-t border-base-300">
    <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-6">
      <div class="flex items-baseline gap-5 min-w-0">
        <span class="font-display text-2xl font-semibold text-base-content leading-none">
          {formattedPrice}
        </span>
        <span class="font-mono text-[11px] uppercase tracking-[0.22em] text-base-content/55 truncate">
          NSW Owner Builder • {c.duration} • Online
        </span>
      </div>
      <a
        href={c.enrolUrl}
        class="btn btn-primary btn-sm sm:btn-md font-semibold whitespace-nowrap"
      >
        Enrol now
      </a>
    </div>
  </div>

</BaseLayout>
