  {/* Page-level demo CSS — these need to be CLASSES (not inline styles)
      because CSP (security.csp: true in astro.config.mjs) strips inline
      `style="..."` attributes. Astro 6 hashes <style> blocks at build
      time and adds the matching sha256 to the CSP allowlist. */}
  <style>
    /* Palette swatch backgrounds — section 02. Add a new colour: append
       an entry to the `palette` array above and a matching rule here. */
    .swatch-primary    { background: #800000; color: #ffffff; }
    .swatch-secondary  { background: #4a5568; color: #ffffff; }
    .swatch-accent     { background: #e2e8f0; color: #1a1a1a; }
    .swatch-neutral    { background: #1a1a1a; color: #ffffff; }
    .swatch-base-100   { background: #ffffff; color: #1a1a1a; }
    .swatch-base-200   { background: #f9fafb; color: #1a1a1a; }
    .swatch-base-300   { background: #e5e7eb; color: #1a1a1a; }
    .swatch-info       { background: #4a5568; color: #ffffff; }
    .swatch-success    { background: #059669; color: #ffffff; }
    .swatch-warning    { background: #d97706; color: #ffffff; }
    .swatch-error      { background: #dc2626; color: #ffffff; }

    /* Spacing-scale demo bars — section 04. Each rule's name embeds the
       pixel width of the corresponding entry in the spacingScale array. */
    .bar-w-4   { width: 4px; }
    .bar-w-8   { width: 8px; }
    .bar-w-12  { width: 12px; }
    .bar-w-16  { width: 16px; }
    .bar-w-24  { width: 24px; }
    .bar-w-32  { width: 32px; }
    .bar-w-48  { width: 48px; }
    .bar-w-64  { width: 64px; }
    .bar-w-96  { width: 96px; }

    /* Radial-progress demo values — section 05 components.
       DaisyUI's radial-progress reads --value as a CSS custom property;
       inline style attributes would normally set it but CSP blocks those. */
    .radial-30   { --value: 30; }
    .radial-60   { --value: 60; }
    .radial-100  { --value: 100; }
  </style>

</BaseLayout>
