---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const courses = await getCollection('courses', (c) => c.data.status === 'published');
---

<BaseLayout
  title="ABE Education — Australian Trades Training & CPD"
  description="Owner Builder courses, White Card training, and CPD for Australian trades. Reviewed by licensed industry experts. Delivered with our partner RTOs."
>
  <div class="max-w-6xl mx-auto px-4">
  <section class="py-12">
    <p class="text-sm uppercase tracking-wide text-base-content/60">ABE Education</p>
    <h1 class="font-display text-4xl font-semibold sm:text-5xl text-base-content">
      Practical training for Australian trades.
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-base-content/80">
      Owner Builder courses, White Card training, and CPD — reviewed by
      licensed builders and industry experts, delivered online with our
      partner Registered Training Organisations.
    </p>
    <p class="mt-6">
      <a class="btn btn-primary btn-lg" href="/compare/owner-builder/">
        Compare Owner Builder requirements by state
      </a>
    </p>
  </section>

  {courses.length > 0 && (
    <section class="mt-12">
      <h2 class="font-display text-2xl font-semibold text-base-content">Available courses</h2>
      <ul class="mt-4 grid gap-4 sm:grid-cols-2">
        {courses.map((c) => (
          <li class="card bg-base-100 border border-base-300">
            <div class="card-body p-6">
              <h3 class="card-title font-display text-lg font-semibold">
                <a href={`/courses/${c.id}/`} class="hover:text-primary">{c.data.title}</a>
              </h3>
              <p class="text-sm text-base-content/70">{c.data.answerCapsule}</p>
              <p class="text-sm text-base-content/60">${c.data.price} {c.data.priceCurrency} &middot; {c.data.duration}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
  </div>
</BaseLayout>
