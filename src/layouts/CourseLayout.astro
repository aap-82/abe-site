---
// CourseLayout — thin shell over BaseLayout for course pages.
// HeroCourse handles the visual hero (title, capsule, CTAs, trust signal).
// This layout just sets the page meta and exposes the schema slot.
// Anything else (post-hero CTA banner, FAQ accordion, related courses)
// goes in the default slot from [...slug].astro.

import BaseLayout from '@/layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  course: CollectionEntry<'courses'>;
  jurisdiction: CollectionEntry<'jurisdictions'>;
  reviewer: CollectionEntry<'experts'>;
}

const { course } = Astro.props;
const d = course.data;
---

<BaseLayout title={d.metaTitle} description={d.metaDescription}>
  <slot name="schema" slot="schema" />
  <slot />
</BaseLayout>
