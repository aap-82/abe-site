# Notion API used by scripts/sync-experts-from-notion.ts
#
# 1. Create an internal integration at https://www.notion.so/profile/integrations
#    (give it Read content capability only — sync only reads).
# 2. Open your Experts database, click ··· → Connections → add the integration.
# 3. Copy the Internal Integration Token below (starts with `ntn_` or `secret_`).
#
# The DB id is the 32-char hex from the database URL:
#   notion.so/<workspace>/<32-char-hex>?v=...
NOTION_TOKEN=
NOTION_EXPERTS_DB_ID=a8dc3f4c431c420092266cf73ab4067b
