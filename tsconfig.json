{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "jsx": "preserve",
    "verbatimModuleSyntax": true
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "*.config.*",
    "*.d.ts",
    "./worker-configuration.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "scripts"
  ]
}